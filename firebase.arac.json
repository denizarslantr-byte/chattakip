{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/tnbLiveVehicles", "function": "tnbLiveVehicles" },
      { "source": "**", "destination": "/index.html" }
